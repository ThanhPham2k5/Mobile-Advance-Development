<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="#1C1C26"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <!-- ── HEADER ROW: icon + tên + badge ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <!-- Icon tròn -->
            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="Au"
                android:textColor="#0A0A0F"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="#D4A843" />

            <!-- Tên loại vàng -->
            <TextView
                android:id="@+id/txtType"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:textColor="#F5F5F0"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- LIVE badge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● LIVE"
                android:textColor="#26D07C"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="#0F2018" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#252535"
            android:layout_marginBottom="14dp" />

        <!-- ── PRICE GRID: 2x2 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <!-- Gram -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GRAM"
                    android:textColor="#55555F"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/txtGram"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#C8C8D8"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

            <!-- Chỉ -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CHỈ"
                    android:textColor="#55555F"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/txtChi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#C8C8D8"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Lượng — highlight vàng -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#1F1800"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LƯỢNG"
                    android:textColor="#9A7520"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/txtLuong"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#D4A843"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

            <View android:layout_width="8dp" android:layout_height="1dp" />

            <!-- Ounce -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#16161F"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OUNCE"
                    android:textColor="#55555F"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/txtOunce"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#C8C8D8"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
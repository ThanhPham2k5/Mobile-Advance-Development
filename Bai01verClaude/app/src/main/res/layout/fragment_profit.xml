<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tính lãi / lỗ vàng"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/bg_primary"
            android:layout_marginBottom="16dp"/>

        <!-- SPINNER TYPE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loại vàng"
            android:textColor="@color/bg_primary"/>

        <Spinner
            android:id="@+id/spinnerType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/bg_primary"
            android:popupBackground="#1E1E1E"
            android:layout_marginBottom="12dp"/>

        <!-- SPINNER UNIT -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đơn vị"
            android:textColor="@color/bg_primary"/>

        <Spinner
            android:id="@+id/spinnerUnit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/bg_primary"
            android:popupBackground="#1E1E1E"
            android:layout_marginBottom="12dp"/>

        <!-- QUANTITY -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Số lượng"
            android:textColor="@color/bg_primary"/>

        <EditText
            android:id="@+id/edtQuantity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nhập số lượng"
            android:inputType="numberDecimal"
            android:textColor="@color/bg_primary"
            android:textColorHint="#AAAAAA"
            android:backgroundTint="@color/bg_primary"
            android:layout_marginBottom="12dp"/>

        <!-- BUY PRICE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Giá mua (VND / đơn vị)"
            android:textColor="@color/bg_primary"/>

        <EditText
            android:id="@+id/edtBuyPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ví dụ: 7000000"
            android:inputType="numberDecimal"
            android:textColor="@color/bg_primary"
            android:textColorHint="#AAAAAA"
            android:backgroundTint="@color/bg_primary"
            android:layout_marginBottom="16dp"/>

        <!-- BUTTON -->
        <Button
            android:id="@+id/btnCalc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tính lãi / lỗ"
            android:backgroundTint="#D4AF37"
            android:textColor="@android:color/black"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- RESULT -->
        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kết quả ...."
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/bg_primary"
            android:padding="12dp"/>

    </LinearLayout>
</ScrollView>
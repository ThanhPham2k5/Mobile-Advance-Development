<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="40dp">

        <!-- ── TITLE ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tính Lãi / Lỗ"
            android:textColor="#D4A843"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mô phỏng lợi nhuận đầu tư vàng"
            android:textColor="#9898A8"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="28dp" />

        <!-- ── CARD: Loại vàng + Đơn vị ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1C1C26"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOẠI VÀNG"
                    android:textColor="#9898A8"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerType"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:popupBackground="#1C1C26"
                    android:layout_marginBottom="16dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#252535"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ĐƠN VỊ"
                    android:textColor="#9898A8"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerUnit"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:popupBackground="#1C1C26" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── CARD: Số lượng + Giá mua ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1C1C26"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SỐ LƯỢNG"
                    android:textColor="#9898A8"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/edtQuantity"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Nhập số lượng…"
                    android:inputType="numberDecimal"
                    android:textColor="#F5F5F0"
                    android:textColorHint="#3A3A4A"
                    android:textSize="18sp"
                    android:background="#13131A"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp"
                    android:selectAllOnFocus="true"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="16dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#252535"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GIÁ MUA"
                    android:textColor="#9898A8"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/edtBuyPrice"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Ví dụ: 7.000.000"
                    android:inputType="numberDecimal"
                    android:textColor="#F5F5F0"
                    android:textColorHint="#3A3A4A"
                    android:textSize="18sp"
                    android:background="#13131A"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp"
                    android:selectAllOnFocus="true"
                    android:paddingEnd="14dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── BUTTON ── -->
        <Button
            android:id="@+id/btnCalc"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="TÍNH LÃI / LỖ"
            android:textColor="#0A0A0F"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:backgroundTint="#D4A843"
            android:layout_marginBottom="20dp" />

        <!-- ── RESULT CARD ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#141208"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="28dp"
                android:paddingBottom="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KẾT QUẢ"
                    android:textColor="#9A7520"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nhập thông tin để tính…"
                    android:textColor="#D4A843"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:lineSpacingExtra="6dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>